<UserControl x:Class="StudyManager.Views.StudiesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:StudyManager.Views"
             xmlns:conv="clr-namespace:StudyManager.Views.Converters"
             xmlns:vm="clr-namespace:StudyManager.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800"
             d:DataContext="{d:DesignInstance Type=vm:StudiesViewModel}">

    <UserControl.Resources>
        <!-- Converters -->
        <conv:PercentageToArcConverter x:Key="PercentageToArcConverter" />
        <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        <conv:InitialsConverter x:Key="InitialsConverter" />
        <conv:LocalImagePathConverter x:Key="LocalImagePathConverter" />
    </UserControl.Resources>

    <Grid Background="{StaticResource BrushWindowBg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header Bar -->
        <Border Grid.Row="0" Background="{StaticResource BrushHeaderBg}" BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,0,0,1.5" Padding="20,0,20,0">
            <Grid>
                <TextBlock Text="Gerenciador de estudos" Style="{StaticResource TextHeader}" VerticalAlignment="Center"/>
                
                <Button Content="Adicionar estudo" Command="{Binding AddStudyCommand}" 
                        Style="{StaticResource PrimaryButton}"
                        HorizontalAlignment="Right" VerticalAlignment="Center"
                        Width="150" Height="36"/>
            </Grid>
        </Border>

        <!-- Main Body -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20">
            <Grid>
                <!-- Empty State Message -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,100,0,0"
                            Visibility="{Binding Studies.Count, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=inverse}">
                    <TextBlock Text="📚" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Text="Nenhum estudo cadastrado." Foreground="{StaticResource BrushTextSecondary}" FontSize="16" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                    <TextBlock Text="Clique em 'Adicionar estudo' no topo para começar!" Foreground="{StaticResource BrushTextMuted}" FontSize="13" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                </StackPanel>

                <!-- Studies List Grid -->
                <ItemsControl ItemsSource="{Binding Studies}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="12" Background="{StaticResource BrushSurfaceBg}" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1.5" Width="260" Height="104" Margin="10" Padding="12" Cursor="Hand"
                                    RenderTransformOrigin="0.5,0.5"
                                    local:DragDropBehavior.IsDragSource="True"
                                    local:DragDropBehavior.IsDropTarget="True"
                                    local:DragDropBehavior.DragGroup="Studies"
                                    local:DragDropBehavior.DropCommand="{Binding DataContext.SyncStudiesCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    local:DragDropBehavior.ClickCommand="{Binding DataContext.OpenStudyCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    local:DragDropBehavior.ClickCommandParameter="{Binding}">
                                <!-- Hover & Click Triggers on the Card -->
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect BlurRadius="8" Color="#000000" Opacity="0.3" ShadowDepth="1"/>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{StaticResource BrushSurfaceHoverBg}"/>
                                                <Setter Property="BorderBrush" Value="{StaticResource BrushPrimary}"/>
                                                <Setter Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect BlurRadius="12" Color="#6366f1" Opacity="0.15" ShadowDepth="2"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                            <Trigger Property="local:DragDropBehavior.IsDragOverItem" Value="True">
                                                <Setter Property="BorderBrush" Value="{StaticResource BrushPrimary}"/>
                                                <Setter Property="Background" Value="{StaticResource BrushSurfaceHoverBg}"/>
                                                <Setter Property="RenderTransform">
                                                    <Setter.Value>
                                                        <ScaleTransform ScaleX="1.03" ScaleY="1.03"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="64"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Column 0: Image / Fallback Placeholder -->
                                    <Border Grid.Column="0" Width="64" Height="64" Background="#11121a" CornerRadius="8" ClipToBounds="True" VerticalAlignment="Center">
                                        <Grid>
                                            <!-- Actual Image -->
                                            <Image Source="{Binding ImagePath, Converter={StaticResource LocalImagePathConverter}}" 
                                                   Stretch="UniformToFill"
                                                   Visibility="{Binding ImagePath, Converter={StaticResource NullToVisibilityConverter}}"/>
                                            <!-- Fallback Text Placeholder -->
                                            <Grid Background="{StaticResource BrushAccent}" Visibility="{Binding ImagePath, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=inverse}">
                                                <TextBlock Text="{Binding Name, Converter={StaticResource InitialsConverter}}" 
                                                           Foreground="White" FontWeight="Bold" FontSize="20"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Grid>
                                    </Border>

                                    <!-- Column 1: Info & Progress -->
                                    <Grid Grid.Column="1" Margin="12,2,0,2">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Row 0: Study Name & Actions -->
                                        <Grid Grid.Row="0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Text="{Binding Name}" Style="{StaticResource TextTitle}" 
                                                       TextTrimming="CharacterEllipsis" VerticalAlignment="Center" HorizontalAlignment="Left"
                                                       MaxWidth="120"/>

                                            <!-- Edit / Delete actions -->
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Button Command="{Binding DataContext.EditStudyCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Content="✏️" ToolTip="Editar" Style="{StaticResource IconButtonStyle}"/>
                                                <Button Command="{Binding DataContext.DeleteStudyCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Content="🗑️" ToolTip="Excluir" Style="{StaticResource IconButtonStyle}"/>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Row 1: Circular Progress -->
                                        <StackPanel Grid.Row="1" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Canvas Width="28" Height="28">
                                                <!-- Background ring -->
                                                <Ellipse Stroke="#15FFFFFF" StrokeThickness="2.5" Width="24" Height="24" Canvas.Left="2" Canvas.Top="2"/>
                                                <!-- Foreground Arc -->
                                                <Path Stroke="{StaticResource BrushPrimary}" StrokeThickness="2.5" 
                                                      Data="{Binding ProgressPercentage, Converter={StaticResource PercentageToArcConverter}}"
                                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                            </Canvas>
                                            <TextBlock Text="{Binding ProgressPercentage, StringFormat={}{0}%}" FontSize="12" FontWeight="Bold"
                                                       Foreground="{StaticResource BrushTextPrimary}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
