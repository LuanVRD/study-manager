<Window x:Class="StudyManager.Views.Dialogs.LinkDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Link" 
        Height="360" Width="450"
        WindowStartupLocation="CenterOwner"
        AllowsTransparency="True"
        WindowStyle="None"
        Background="Transparent"
        ResizeMode="NoResize">

    <Window.Resources>
        <!-- Custom RadioButton Style matching our Dark Theme -->
        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
            <Setter Property="Background" Value="#1A1B26"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <BulletDecorator Background="Transparent" SnapsToDevicePixels="true">
                            <BulletDecorator.Bullet>
                                <Border x:Name="bulletBorder"
                                        Width="18" Height="18"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="9"
                                        SnapsToDevicePixels="true">
                                    <Ellipse x:Name="checkDot"
                                             Fill="White"
                                             Width="8" Height="8"
                                             Visibility="Collapsed"/>
                                </Border>
                            </BulletDecorator.Bullet>
                            <ContentPresenter Margin="8,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                        </BulletDecorator>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="true">
                                <Setter TargetName="bulletBorder" Property="Background" Value="{StaticResource BrushPrimary}"/>
                                <Setter TargetName="bulletBorder" Property="BorderBrush" Value="{StaticResource BrushPrimary}"/>
                                <Setter TargetName="checkDot" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="bulletBorder" Property="BorderBrush" Value="{StaticResource BrushPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Border CornerRadius="12" Background="{StaticResource BrushSurfaceBg}" BorderBrush="{StaticResource BrushBorder}" BorderThickness="2" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Color="#000000" Opacity="0.5" ShadowDepth="2"/>
        </Border.Effect>
        
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" MouseLeftButtonDown="Header_MouseLeftButtonDown" Background="Transparent">
                <TextBlock x:Name="TitleTextBlock" Text="Adicionar Link" Style="{StaticResource TextTitle}" VerticalAlignment="Center"/>
                <Button Content="✕" Click="Cancel_Click" HorizontalAlignment="Right" VerticalAlignment="Center" 
                        Background="Transparent" BorderBrush="Transparent" Foreground="{StaticResource BrushTextSecondary}" FontSize="16" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

            <!-- Form Content -->
            <StackPanel Grid.Row="1" Margin="0,15,0,15" VerticalAlignment="Center">
                <!-- Nome -->
                <TextBlock Text="Nome do Link *" Style="{StaticResource TextBody}" Margin="0,0,0,6" FontWeight="SemiBold"/>
                <TextBox x:Name="NameTextBox" Height="38" FontSize="14"/>

                <!-- URL -->
                <TextBlock Text="URL *" Style="{StaticResource TextBody}" Margin="0,12,0,6" FontWeight="SemiBold"/>
                <TextBox x:Name="UrlTextBox" Height="38" FontSize="14"/>

                <!-- Tipo -->
                <TextBlock Text="Tipo de Link *" Style="{StaticResource TextBody}" Margin="0,12,0,8" FontWeight="SemiBold"/>
                <StackPanel Orientation="Horizontal">
                    <RadioButton x:Name="VideoRadioButton" Content="Vídeo" IsChecked="True" GroupName="LinkTypeGroup" Margin="0,0,24,0"/>
                    <RadioButton x:Name="ArticleRadioButton" Content="Matéria / Artigo" GroupName="LinkTypeGroup"/>
                </StackPanel>
            </StackPanel>

            <!-- Actions Footer -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancelar" Click="Cancel_Click" Style="{StaticResource SecondaryButton}" Width="100" Height="38" Margin="0,0,8,0"/>
                <Button Content="Salvar" Click="Save_Click" Style="{StaticResource PrimaryButton}" Width="100" Height="38"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
