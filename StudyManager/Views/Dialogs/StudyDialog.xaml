<Window x:Class="StudyManager.Views.Dialogs.StudyDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Estudo" 
        Height="350" Width="450"
        WindowStartupLocation="CenterOwner"
        AllowsTransparency="True"
        WindowStyle="None"
        Background="Transparent"
        ResizeMode="NoResize">
    
    <Border CornerRadius="12" Background="{StaticResource BrushSurfaceBg}" BorderBrush="{StaticResource BrushBorder}" BorderThickness="2" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Color="#000000" Opacity="0.5" ShadowDepth="2"/>
        </Border.Effect>
        
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" MouseLeftButtonDown="Header_MouseLeftButtonDown" Background="Transparent">
                <TextBlock x:Name="TitleTextBlock" Text="Adicionar Estudo" Style="{StaticResource TextTitle}" VerticalAlignment="Center"/>
                <Button Content="✕" Click="Cancel_Click" HorizontalAlignment="Right" VerticalAlignment="Center" 
                        Background="Transparent" BorderBrush="Transparent" Foreground="{StaticResource BrushTextSecondary}" FontSize="16" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

            <!-- Form Content -->
            <StackPanel Grid.Row="1" Margin="0,20,0,20" VerticalAlignment="Center">
                <!-- Nome -->
                <TextBlock Text="Nome do Estudo *" Style="{StaticResource TextBody}" Margin="0,0,0,6" FontWeight="SemiBold"/>
                <TextBox x:Name="NameTextBox" Height="38" FontSize="14"/>

                <!-- Imagem -->
                <TextBlock Text="Imagem de Capa (Opcional)" Style="{StaticResource TextBody}" Margin="0,16,0,6" FontWeight="SemiBold"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBox x:Name="ImagePathTextBox" IsReadOnly="True" Height="38" FontSize="12" Foreground="{StaticResource BrushTextSecondary}"/>
                    
                    <Button Grid.Column="1" Content="Selecionar..." Click="SelectImage_Click" Style="{StaticResource AccentButton}" Width="100" Height="38" Margin="8,0,0,0"/>
                </Grid>
            </StackPanel>

            <!-- Actions Footer -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancelar" Click="Cancel_Click" Style="{StaticResource SecondaryButton}" Width="100" Height="38" Margin="0,0,8,0"/>
                <Button Content="Salvar" Click="Save_Click" Style="{StaticResource PrimaryButton}" Width="100" Height="38"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
