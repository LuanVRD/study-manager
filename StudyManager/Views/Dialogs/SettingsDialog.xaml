<Window x:Class="StudyManager.Views.Dialogs.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configurações" 
        Height="250" Width="450"
        WindowStartupLocation="CenterOwner"
        AllowsTransparency="True"
        WindowStyle="None"
        Background="Transparent"
        ResizeMode="NoResize">
    
    <Border CornerRadius="12" Background="{StaticResource BrushSurfaceBg}" BorderBrush="{StaticResource BrushBorder}" BorderThickness="2" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Color="#000000" Opacity="0.5" ShadowDepth="2"/>
        </Border.Effect>
        
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" MouseLeftButtonDown="Header_MouseLeftButtonDown" Background="Transparent">
                <TextBlock Text="Configurações" Style="{StaticResource TextTitle}" VerticalAlignment="Center"/>
                <Button Content="✕" Click="Cancel_Click" HorizontalAlignment="Right" VerticalAlignment="Center" 
                        Background="Transparent" BorderBrush="Transparent" Foreground="{StaticResource BrushTextSecondary}" FontSize="16" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

            <!-- Form Content -->
            <StackPanel Grid.Row="1" Margin="0,20,0,20" VerticalAlignment="Center">
                <TextBlock Text="Chave da API do Gemini" Style="{StaticResource TextBody}" Margin="0,0,0,6" FontWeight="SemiBold"/>
                <TextBox x:Name="ApiKeyTextBox" Height="38" FontSize="14" ToolTip="Insira a chave da API do Gemini (gemini-2.5-flash)"/>
            </StackPanel>

            <!-- Actions Footer -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancelar" Click="Cancel_Click" Style="{StaticResource SecondaryButton}" Width="100" Height="38" Margin="0,0,8,0"/>
                <Button Content="Salvar" Click="Save_Click" Style="{StaticResource PrimaryButton}" Width="100" Height="38"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
